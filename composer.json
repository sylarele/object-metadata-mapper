{
    "name": "sylarele/object-metadata-mapper",
    "type": "library",
    "license": "MIT",
    "require": {
        "php": "^8.3"
    },
    "require-dev": {
        "friendsofphp/php-cs-fixer": "^3.65",
        "phpstan/phpstan": "^2.0",
        "phpunit/phpunit": "^11.5",
        "rector/rector": "^2.0",
        "shipmonk/composer-dependency-analyser": "^1.8"
    },
    "autoload": {
        "psr-4": {
            "Sylarele\\ObjectMetadataMapper\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Sylarele\\ObjectMetadataMapper\\Tests\\": "tests/"
        }
    },
    "config": {
        "optimize-autoloader": true,
        "preferred-install": "dist",
        "sort-packages": true
    }
}
